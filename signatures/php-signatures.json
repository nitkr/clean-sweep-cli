{
  "version": "1.0.0",
  "description": "PHP malware signatures for Clean Sweep CLI",
  "lastUpdated": "2026-03-23",
  "signatures": [
    {
      "id": "php-webshell-001",
      "name": "Base64 Encoded Webshell",
      "description": "Uses base64_decode with eval to execute encoded commands",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*base64_decode",
      "type": "webshell",
      "category": "remote-code-execution"
    },
    {
      "id": "php-webshell-002",
      "name": "POST-based Webshell",
      "description": "Executes commands sent via POST parameters",
      "severity": "critical",
      "pattern": "\\$_POST.*eval|eval\\s*\\(\\s*\\$_POST",
      "type": "webshell",
      "category": "remote-code-execution"
    },
    {
      "id": "php-webshell-003",
      "name": "GET-based Command Execution",
      "description": "Executes commands from GET parameters",
      "severity": "critical",
      "pattern": "shell_exec\\s*\\(\\s*\\$_GET",
      "type": "webshell",
      "category": "remote-code-execution"
    },
    {
      "id": "php-webshell-003b",
      "name": "POST-based Command Execution",
      "description": "Executes commands from POST parameters",
      "severity": "critical",
      "pattern": "shell_exec\\s*\\(\\s*\\$_POST",
      "type": "webshell",
      "category": "remote-code-execution"
    },
    {
      "id": "php-webshell-003c",
      "name": "REQUEST-based Command Execution",
      "description": "Executes commands from REQUEST parameters",
      "severity": "critical",
      "pattern": "shell_exec\\s*\\(\\s*\\$_REQUEST",
      "type": "webshell",
      "category": "remote-code-execution"
    },
    {
      "id": "php-webshell-004",
      "name": "Hidden Input Webshell",
      "description": "Uses hidden form inputs for command injection",
      "severity": "high",
      "pattern": "<input[^>]*type\\s*=\\s*['\"]hidden['\"][^>]*name\\s*=\\s*['\"]cmd",
      "type": "webshell",
      "category": "remote-code-execution"
    },

    {
      "id": "php-backdoor-001",
      "name": "Function Callback Backdoor with User Input",
      "description": "Uses call_user_func with user input for dynamic code execution",
      "severity": "critical",
      "pattern": "call_user_func\\s*\\(\\s*\\$(?:GET|POST|REQUEST|COOKIE|SERVER)",
      "type": "backdoor",
      "category": "remote-code-execution"
    },
    {
      "id": "php-backdoor-002",
      "name": "Create Function Backdoor",
      "description": "Creates anonymous functions dynamically",
      "severity": "critical",
      "pattern": "create_function\\s*\\(",
      "type": "backdoor",
      "category": "remote-code-execution"
    },
    {
      "id": "php-backdoor-003",
      "name": "preg_replace /e Callback with Obfuscation",
      "description": "Uses preg_replace with /e modifier combined with encoding functions for code execution",
      "severity": "critical",
      "pattern": "preg_replace\\s*\\([^)]*\\/e[^)]*(?:base64_decode|gzinflate|gzuncompress|eval)",
      "type": "backdoor",
      "category": "remote-code-execution"
    },
    {
      "id": "php-backdoor-004",
      "name": "assert() with Obfuscation",
      "description": "Uses assert() combined with encoding functions for dynamic code execution",
      "severity": "critical",
      "pattern": "assert\\s*\\(\\s*(?:base64_decode|gzinflate|gzuncompress)\\s*\\(",
      "type": "backdoor",
      "category": "remote-code-execution"
    },
    {
      "id": "php-backdoor-005",
      "name": "Array Map Execution with User Input",
      "description": "Uses array_map with user input data for code execution",
      "severity": "high",
      "pattern": "array_map\\s*\\(\\s*\\$[a-zA-Z_]\\w*,\\s*\\$_(?:GET|POST|REQUEST|COOKIE)",
      "type": "backdoor",
      "category": "remote-code-execution"
    },



    {
      "id": "php-encoded-005",
      "name": "Chunk Split with User Input",
      "description": "Uses chunk_split with user input for encoding manipulation",
      "severity": "medium",
      "pattern": "chunk_split\\s*\\(\\s*\\$_(?:GET|POST|REQUEST|COOKIE)",
      "type": "encoded-shell",
      "category": "obfuscation"
    },

    {
      "id": "php-suspicious-002",
      "name": "Proc Open Execution",
      "description": "Uses proc_open for process manipulation",
      "severity": "high",
      "pattern": "proc_open\\s*\\(",
      "type": "suspicious-function",
      "category": "system-command"
    },
    {
      "id": "php-suspicious-003",
      "name": "PCNTL Process Control",
      "description": "Uses pcntl_exec for process execution",
      "severity": "high",
      "pattern": "pcntl_exec\\s*\\(",
      "type": "suspicious-function",
      "category": "system-command"
    },
    {
      "id": "php-suspicious-004",
      "name": "URL File Access",
      "description": "Uses file_get_contents with URLs",
      "severity": "medium",
      "pattern": "file_get_contents\\s*\\(\\s*['\"]http",
      "type": "suspicious-function",
      "category": "network-access"
    },
    {
      "id": "php-suspicious-006",
      "name": "Multiple Encoding Layers with eval",
      "description": "Multiple encoding functions chained with eval execution",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*(?:base64_decode|gzinflate|gzuncompress|str_rot13)\\s*\\([^)]*\\$[^)]*\\)",
      "type": "multi-layer-obfuscation",
      "category": "obfuscation"
    },
    {
      "id": "php-suspicious-007",
      "name": "Variable Function Call with Dangerous Functions",
      "description": "Uses variable function names with dangerous encoding functions",
      "severity": "high",
      "pattern": "\\$[a-zA-Z_]\\w*\\s*\\(\\s*(?:base64_decode|gzinflate|gzuncompress|str_rot13|eval)\\s*\\(",
      "type": "dynamic-function",
      "category": "remote-code-execution"
    },
    {
      "id": "php-suspicious-009",
      "name": "Eval with Variable",
      "description": "Uses eval with variable content",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*\\$",
      "type": "suspicious-function",
      "category": "remote-code-execution"
    },
    {
      "id": "php-suspicious-010",
      "name": "Include/Require Remote",
      "description": "Includes or requires remote files",
      "severity": "critical",
      "pattern": "(include|require)\\s*\\(\\s*['\"]http",
      "type": "remote-inclusion",
      "category": "remote-code-execution"
    }
  ]
}
