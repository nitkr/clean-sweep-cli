{
  "version": "1.0.0",
  "description": "JavaScript malware signatures for Clean Sweep CLI",
  "lastUpdated": "2026-03-23",
  "signatures": [
    {
      "id": "js-eval-001",
      "name": "Dynamic eval()",
      "description": "Uses eval() with string literal for code execution",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*['\"`]",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-eval-002",
      "name": "Template Literal eval",
      "description": "Uses eval() with template literal",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*`",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-eval-003",
      "name": "Concatenated eval",
      "description": "Uses eval() with string concatenation",
      "severity": "critical",
      "pattern": "eval\\s*\\([^)]*\\+[^)]*\\)",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-eval-005",
      "name": "setTimeout Code Execution",
      "description": "Uses setTimeout with string for code execution",
      "severity": "high",
      "pattern": "setTimeout\\s*\\(\\s*['\"`]",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-eval-006",
      "name": "setInterval Code Execution",
      "description": "Uses setInterval with string for code execution",
      "severity": "high",
      "pattern": "setInterval\\s*\\(\\s*['\"`]",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-api-001",
      "name": "Child Process exec",
      "description": "Executes system commands via child_process",
      "severity": "critical",
      "pattern": "child_process.*\\.exec\\s*\\(",
      "type": "suspicious-api",
      "category": "system-command"
    },
    {
      "id": "js-api-002",
      "name": "Child Process spawn",
      "description": "Spawns processes via child_process",
      "severity": "high",
      "pattern": "child_process.*spawn\\s*\\(",
      "type": "suspicious-api",
      "category": "system-command"
    },
    {
      "id": "js-api-003",
      "name": "Process Module Require",
      "description": "Requires process module in suspicious context",
      "severity": "high",
      "pattern": "require\\s*\\(\\s*['\"]process['\"]",
      "type": "suspicious-api",
      "category": "system-info"
    },
    {
      "id": "js-api-004",
      "name": "Process Binding Access",
      "description": "Accesses internal Node.js bindings",
      "severity": "critical",
      "pattern": "process\\.binding\\s*\\(",
      "type": "suspicious-api",
      "category": "system-info"
    },
    {
      "id": "js-api-006",
      "name": "eval() with Variable",
      "description": "Uses eval with variable content",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*\\$",
      "type": "malicious-eval",
      "category": "code-execution"
    },
    {
      "id": "js-xss-001",
      "name": "document.write Usage",
      "description": "Uses document.write for dynamic content",
      "severity": "medium",
      "pattern": "document\\.write\\s*\\(",
      "type": "xss",
      "category": "cross-site-scripting"
    },
    {
      "id": "js-xss-003",
      "name": "outerHTML Assignment",
      "description": "Uses outerHTML with potentially unsafe data",
      "severity": "medium",
      "pattern": "\\.outerHTML\\s*=",
      "type": "xss",
      "category": "cross-site-scripting"
    },
    {
      "id": "js-xss-004",
      "name": "insertAdjacentHTML Usage",
      "description": "Uses insertAdjacentHTML with dynamic content",
      "severity": "medium",
      "pattern": "insertAdjacentHTML\\s*\\(",
      "type": "xss",
      "category": "cross-site-scripting"
    },
    {
      "id": "js-xss-005",
      "name": "eval-based XSS",
      "description": "Uses eval to execute potentially malicious content",
      "severity": "critical",
      "pattern": "eval\\s*\\(\\s*(location|document|window)",
      "type": "xss",
      "category": "cross-site-scripting"
    },
    {
      "id": "js-obfuscation-002",
      "name": "Unescape Usage",
      "description": "Uses unescape for decoding obfuscated content",
      "severity": "medium",
      "pattern": "unescape\\s*\\(",
      "type": "obfuscation",
      "category": "obfuscation"
    },
    {
      "id": "js-suspicious-001",
      "name": "Remote Script Loading",
      "description": "Loads scripts from external URLs",
      "severity": "high",
      "pattern": "<script[^>]+src\\s*=\\s*['\"]http",
      "type": "suspicious",
      "category": "remote-code"
    },
    {
      "id": "js-suspicious-005",
      "name": "LocalStorage Access",
      "description": "Accesses localStorage for data storage",
      "severity": "low",
      "pattern": "localStorage\\.(setItem|getItem)",
      "type": "suspicious",
      "category": "data-storage"
    }
  ]
}
