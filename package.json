{
  "name": "clean-sweep-cli",
  "version": "1.0.0",
  "description": "CLI tool for cleaning and managing project files",
  "main": "dist/index.js",
  "bin": {
    "clean-sweep": "./bin/clean-sweep"
  },
  "scripts": {
    "build": "tsc",
    "build:pkg": "pkg . --out-path dist/pkg",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "pkg": {
    "assets": [
      "signatures/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "dist/pkg"
  },
  "keywords": [
    "cli",
    "clean",
    "sweep",
    "cleanup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "fast-glob": "^3.3.2",
    "node-fetch": "^3.3.2",
    "tar": "^7.5.12",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/commander": "^2.12.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "jest": "^30.3.0",
    "pkg": "^5.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.2"
  }
}
